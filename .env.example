# =============================================================================
# Agent Stack Template — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Backend ---
ANTHROPIC_API_KEY=sk-ant-...          # Required: Anthropic API key
STORAGE_BACKEND=memory                # memory | local
FRONTEND_URL=http://localhost:3000    # CORS origin for production

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000  # Backend URL
