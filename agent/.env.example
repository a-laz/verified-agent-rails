ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
# Base Sepolia RPC for the AgentBook lookupHuman read (identity lives here).
# The public default https://sepolia.base.org works but is rate limited; use a
# dedicated endpoint (Alchemy/Infura/etc.) for anything beyond the proof script.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Dynamic MPC server wallet credentials (Saturday workstream)
# Environment ID is public (same value web exposes via NEXT_PUBLIC_).
DYNAMIC_ENVIRONMENT_ID=
# API token is SECRET. Generate at app.dynamic.xyz -> Developers -> API Tokens.
# Starts with dyn_. Never commit the real value; it belongs only in agent/.env.
DYNAMIC_API_TOKEN=
