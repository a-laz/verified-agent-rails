# World ID via AgentKit (Saturday workstream)
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_ACTION_ID=
# Dynamic (Saturday workstream)
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
# Registered demo agent the dashboard reads. Defaults to the live agent if unset.
NEXT_PUBLIC_AGENT_ADDRESS=
# Attestor signing key for the /api/var/grant route. SERVER-ONLY (not NEXT_PUBLIC):
# it must never reach the browser. Same dedicated attestor key registered on the
# mirror; the route signs, the connected wallet relays. SECRET, keep out of git.
ATTESTOR_PRIVATE_KEY=
# Optional dedicated RPCs for the grant/agent/register routes. Default to viem
# public endpoints.
ARC_TESTNET_RPC_URL=
WORLDCHAIN_RPC_URL=
# Optional override for the gasless AgentBook registration relay used by
# /api/var/register. Defaults to https://x402-worldchain.vercel.app.
NEXT_PUBLIC_REGISTER_RELAY_URL=
# Agent MPC signing (SERVER-ONLY) for /api/var/pay (agent spends through the
# gate) and /api/var/create-agent (mint a new agent wallet). Copy from
# agent/.env and agent/.agent-wallet.json. SECRETS, keep out of git.
DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_API_TOKEN=
AGENT_WALLET_PASSWORD=
# walletId of the agent the pay route signs as (from agent/.agent-wallet.json).
AGENT_WALLET_ID=
